# Max-DeepSeek local config
# Copy to .env or set these in docker/docker-compose.yml.

HOST=0.0.0.0
PORT=22218
DATA_DIR=/app/data

# Comma-separated origins allowed to call the admin/API server from browsers.
# Use * only for local testing.
CORS_ORIGINS=http://localhost:22218,http://127.0.0.1:22218

# Admin JWT lifetime in seconds.
ADMIN_JWT_EXPIRE_SECONDS=86400

# DeepSeek upstream / proxy settings.
DS_API_BASE=https://chat.deepseek.com/api/v0
DS_PROXY_URL=
DS_WASM_URL=https://fe-static.deepseek.com/chat/static/sha3_wasm_bg.7b9ca65ddd.wasm
DS_USER_AGENT=DeepSeek/2.0.4 Android/35
DS_CLIENT_VERSION=2.1.0
DS_CLIENT_PLATFORM=android
DS_CLIENT_LOCALE=zh_CN
DS_IMPERSONATE=chrome

# Pool tuning.
DS_RECOVERY_INTERVAL=20
DS_ACQUIRE_TIMEOUT_MS=10000
DS_MIN_ACCOUNT_INTERVAL_MS=45000
DS_MAX_ATTEMPTS=2
DS_INIT_CONCURRENCY=2
DS_AUTO_DISABLE_AFTER_STRIKES=6
DS_HEALTHCHECK_ON_LOGIN=0
